#!/bin/bash
trap 'echo "Killing process"; kill 0' EXIT

DIR="$1"

# Resolve the directory where this script lives,
# so companion scripts are found regardless of install location.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OPTIMIZER_SCRIPT="$SCRIPT_DIR/jpgpngoptimizer"
FINDNOPTIMIZE_SCRIPT="$SCRIPT_DIR/findimgswithoutattr"

echo "Starting process"
$FINDNOPTIMIZE_SCRIPT $1 &

inotifywait -r -m -q -e create --format %w%f $DIR | while read FILE
do
    $OPTIMIZER_SCRIPT "$FILE" && attr -s optimized -V yes "$FILE"
done
